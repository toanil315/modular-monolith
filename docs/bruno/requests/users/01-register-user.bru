meta {
  name: 01 - Register User
  type: http
  seq: 1
}

post {
  url: {{baseURL}}/users
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "firstName": "Ada",
    "lastName": "Lovelace",
    "email": "ada.lovelace@example.com",
    "password": "ChangeMe123!"
  }
}

tests {
  test("status is 2xx", function() {
    expect(res.status).to.be.within(200, 299);
    expect(res.body).to.be.an("object");
  });
}
